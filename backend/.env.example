# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
# local | prod
APP_ENV=local

# ─────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────
# Database
# Local: docker-compose postgres
# AWS:   postgresql://user:pass@rds-endpoint:5432/careeriq
# ─────────────────────────────────────────
DATABASE_URL=postgresql://careeriq:careeriq@localhost:5432/careeriq

# ─────────────────────────────────────────
# AWS
# Local: dummy credentials required by boto3 even for LocalStack
# AWS:   real credentials (or IAM role — leave blank on ECS)
# ─────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# AWS endpoint override
# Local: http://localhost:4566  (LocalStack)
# AWS:   leave blank — boto3 uses real AWS endpoints
AWS_ENDPOINT_URL=http://localhost:4566

# S3
# Local: careeriq-assets-local (created by localstack/init/init-aws.sh)
# AWS:   careeriq-assets-{account-id}
S3_BUCKET_NAME=careeriq-assets-local

# SQS
# Queue name used to build or resolve the queue URL
QUEUE_NAME=careeriq-jobs
# Full queue URL — can be derived from QUEUE_NAME but explicit is safer
# Local: http://localhost:4566/000000000000/careeriq-jobs
# AWS:   https://sqs.us-east-1.amazonaws.com/{account-id}/careeriq-jobs
SQS_QUEUE_URL=http://localhost:4566/000000000000/careeriq-jobs

# ─────────────────────────────────────────
# Backend (FastAPI)
# ─────────────────────────────────────────
BACKEND_SECRET_KEY=local-dev-secret
BACKEND_CORS_ORIGINS=http://localhost:5173
