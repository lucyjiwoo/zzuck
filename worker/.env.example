# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
# local | prod
APP_ENV=local

# ─────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────
# Database
# Local: docker-compose postgres
# AWS:   postgresql://user:pass@rds-endpoint:5432/zzuck
# ─────────────────────────────────────────
DATABASE_URL=postgresql://zzuck:zzuck@localhost:5432/zzuck

# ─────────────────────────────────────────
# AWS
# Local: dummy credentials required by boto3 even for LocalStack
# AWS:   real credentials (or IAM role — leave blank on ECS)
# ─────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# AWS endpoint override
# Local: http://localhost:4566  (LocalStack)
# AWS:   leave blank — boto3 uses real AWS endpoints
AWS_ENDPOINT_URL=http://localhost:4566

# S3
# Local: zzuck-assets-local (created by localstack/init/init-aws.sh)
# AWS:   zzuck-assets-{account-id}
S3_BUCKET_NAME=zzuck-assets-local

# SQS
# Queue name used to build or resolve the queue URL
QUEUE_NAME=zzuck-jobs
# Full queue URL — can be derived from QUEUE_NAME but explicit is safer
# Local: http://localhost:4566/000000000000/zzuck-jobs
# AWS:   https://sqs.us-east-1.amazonaws.com/{account-id}/zzuck-jobs
SQS_QUEUE_URL=http://localhost:4566/000000000000/zzuck-jobs

# ─────────────────────────────────────────
# Worker
# ─────────────────────────────────────────
POLL_INTERVAL_SECONDS=5
